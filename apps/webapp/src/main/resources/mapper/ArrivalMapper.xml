<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.frere.infrastructure.persistence.mybatis.ArrivalMapper">

    <resultMap id="arrivalResultMap" type="com.example.frere.domain.model.arrival.Arrival">
        <id property="arrivalId" column="arrival_id"/>
        <result property="purchaseOrderId" column="purchase_order_id"/>
        <result property="itemId" column="item_id"/>
        <result property="quantity" column="quantity"/>
        <result property="arrivalDate" column="arrival_date"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="arrivalResultMap">
        SELECT arrival_id, purchase_order_id, item_id, quantity, arrival_date, created_at
        FROM arrivals
    </select>

    <select id="findById" resultMap="arrivalResultMap">
        SELECT arrival_id, purchase_order_id, item_id, quantity, arrival_date, created_at
        FROM arrivals
        WHERE arrival_id = #{arrivalId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="arrivalId">
        INSERT INTO arrivals (purchase_order_id, item_id, quantity, arrival_date)
        VALUES (#{purchaseOrderId}, #{itemId}, #{quantity}, #{arrivalDate})
    </insert>

    <delete id="deleteById">
        DELETE FROM arrivals WHERE arrival_id = #{arrivalId}
    </delete>

</mapper>
